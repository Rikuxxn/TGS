//=============================================================================
// 変数
//=============================================================================
samplerCUBE gSkyCube : register(s0);// キューブマップ用サンプラ

//=============================================================================
// ピクセルシェーダ入力
//=============================================================================
struct PS_INPUT
{
    float3 Dir : TEXCOORD0;
};

//=============================================================================
// ピクセルシェーダ本体
//=============================================================================
float4 PSMain(PS_INPUT In) : COLOR0
{
    // 方向ベクトルの正規化
    float3 dir = normalize(In.Dir);

    return texCUBE(gSkyCube, dir);
}
